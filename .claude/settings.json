{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sdk_lint.sh",
            "timeout": 10,
            "statusMessage": "Checking SDK patterns..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/test_coverage.sh",
            "timeout": 15,
            "statusMessage": "Checking test coverage..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/public_api_test_check.sh",
            "timeout": 15,
            "statusMessage": "Checking public API tests..."
          },
          {
            "type": "command",
            "command": "path=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // empty'); [ -z \"$path\" ] && exit 0; echo \"$path\" | grep -qE '\\.py$' || exit 0; result=$(uv run pyright \"$path\" 2>&1); rc=$?; [ $rc -ne 0 ] && echo \"Pyright: $(echo \"$result\" | grep -E 'error|warning' | head -5)\" >&2; exit 0",
            "timeout": 30,
            "statusMessage": "Type checking..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/docs_scope_guard.sh",
            "timeout": 5,
            "statusMessage": "Checking docs scope..."
          }
        ]
      }
    ]
  }
}
